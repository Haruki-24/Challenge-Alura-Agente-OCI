      },
      "source": [
        "### 2.4 - Vectorización (Embedings)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Inicialización dinámicam de la clase de embeddings correspondiente al proveedor definido globalmente."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 104,
          "referenced_widgets": [
            "6766cb5bcb9e42fba064dacb110638ec",
            "c590bd3c8ef74bf889d0aefbc9dc9e60",
            "a36cd376304f4a63aec11bd71822fba1",
            "210cd4b176974a1e808efdf398dc82f3",
            "dd2f5460c59448a9a0191d00c5bb1c9e",
            "225a897863024a58932f25c51997175e",
            "697d73165b764e299ce96c332a6f3514",
            "7dc96149c7074c2d8caa5f7295a3323f",
            "5aad7c35a93a44f49e59db7584d2db94",
            "8a289b730a1e412cb9455da29c791393",
            "0c15b26d55234f0cb7cc698513988665"
          ]
        },
        "id": "n-cJbnNLLg0L",
        "outputId": "c37e9208-726b-4fce-b24c-b6753c85afc8"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Inicializando modelo de Embeddings: HUGGINGFACE...\n"
          ]
        },
        {
          "data": {
            "application/vnd.jupyter.widget-view+json": {
              "model_id": "6766cb5bcb9e42fba064dacb110638ec",
              "version_major": 2,
              "version_minor": 0
            },
            "text/plain": [
              "Loading weights:   0%|          | 0/199 [00:00<?, ?it/s]"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        },
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Generando base de datos vectorial FAISS...\n",
            "¡Base de datos FAISS guardada con éxito en '/content/faiss_index_oci'!\n"
          ]
        }
      ],
      "source": [
        "from langchain_community.vectorstores import FAISS\n",
        "\n",
        "print(f\"Inicializando modelo de Embeddings: {EMBEDDING_PROVIDER.upper()}...\")\n",
        "\n",
        "# 1. Inicialización dinámica del Embedding Class\n",
        "if EMBEDDING_PROVIDER == \"huggingface\":\n",
        "    from langchain_huggingface import HuggingFaceEmbeddings\n",
        "    model_kwargs = {'device': 'cpu'}  # Cambiar a 'cuda' si tienes una GPU activa en Colab\n",
        "    encode_kwargs = {'normalize_embeddings': True}\n",
        "    embeddings_local = HuggingFaceEmbeddings(\n",
        "        model_name=EMBEDDING_MODEL_NAME,\n",
        "        model_kwargs=model_kwargs,\n",
        "        encode_kwargs=encode_kwargs\n",
        "    )\n",
        "\n",
        "elif EMBEDDING_PROVIDER == \"google\":\n",
        "    cargar_api_key('Gemini-GC', 'GOOGLE_API_KEY')\n",
        "    from langchain_google_genai import GoogleGenerativeAIEmbeddings\n",
        "    embeddings_local = GoogleGenerativeAIEmbeddings(model=EMBEDDING_MODEL_NAME)\n",
        "\n",
        "elif EMBEDDING_PROVIDER == \"openai\":\n",
        "    cargar_api_key('OPENAI_API_KEY', 'OPENAI_API_KEY')\n",
        "    from langchain_openai import OpenAIEmbeddings\n",
        "    embeddings_local = OpenAIEmbeddings(model=EMBEDDING_MODEL_NAME)\n",
        "\n",
        "elif EMBEDDING_PROVIDER == \"cohere\":\n",
        "    cargar_api_key('COHERE_API_KEY', 'COHERE_API_KEY')\n",
        "    from langchain_cohere import CohereEmbeddings\n",
        "    embeddings_local = CohereEmbeddings(model=EMBEDDING_MODEL_NAME)\n",
        "\n",
        "else:\n",
        "    raise ValueError(f\"Proveedor de Embeddings no soportado: {EMBEDDING_PROVIDER}\")\n",
        "\n",
        "# 2. Ruta de persistencia local en Colab\n",
        "FAISS_DB_PATH = \"/content/faiss_index_oci\"\n",
        "\n",
        "print(\"Generando base de datos vectorial FAISS...\")\n",
        "try:\n",
        "    # Creamos el índice utilizando los fragmentos procesados y la instancia de embeddings configurada\n",
        "    db = FAISS.from_documents(documentos_fragmentados, embeddings_local)\n",
        "\n",
        "    # Guardamos localmente el índice estructurado\n",
        "    db.save_local(FAISS_DB_PATH)\n",
